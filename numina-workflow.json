                  {
                      "parameters":  {
                                         "jsCode":  "// Zpracujeme odpověď z Gemini a zjistíme, zda je potřeba eskalace\nfunction extractText(value) {\n  if (!value) return \u0027\u0027;\n  if (typeof value === \u0027string\u0027) return value;\n  if (Array.isArray(value)) return value.map(extractText).filter(Boolean).join(\u0027 \u0027);\n  if (typeof value === \u0027object\u0027) {\n    if (value.text) return extractText(value.text);\n    if (value.output) return extractText(value.output);\n    if (value.content) return extractText(value.content);\n    if (value.response) return extractText(value.response);\n    if (value.parts) return extractText(value.parts);\n    if (value.candidates) return extractText(value.candidates);\n  }\n  return \u0027\u0027;\n}\n\nlet reply = extractText($json).trim();\n\nconst needsEscalation = reply.includes(\u0027[ESKALACE]\u0027);\nreply = reply.replace(/\\[ESKALACE\\]/g, \u0027\u0027).trim();\n\nif (!reply) {\n  reply = \u0027Děkujeme za zprávu. Předávám ji týmu NUMINA a brzy se vám ozveme s konkrétní odpovědí.\u0027;\n}\n\nconst ctx = $(\u0027Sestav kontext\u0027).first().json;\n\nreturn [{\n  json: {\n    conversationId: ctx.conversationId,\n    name: ctx.name,\n    email: ctx.email,\n    userMessage: ctx.userMessage,\n    reply,\n    needsEscalation,\n    isFirstMessage: ctx.isFirstMessage\n  }\n}];"
                                     },
