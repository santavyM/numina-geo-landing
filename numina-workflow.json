                      "id":  "sheets-read",
                      "name":  "Načti historii vlákna",
                      "type":  "n8n-nodes-base.googleSheets",
                      "typeVersion":  4.5,
                      "position":  [
                                       -420,
                                       300
                                   ],
                      "alwaysOutputData":  true
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Sestavíme historii konverzace do textu pro AI\nconst incoming = $(\u0027Webhook (zpráva z webu)\u0027).first().json.body;\nconst conversationId = incoming.conversationId;\nconst name = incoming.name || \u0027Neznámý\u0027;\nconst email = incoming.email || \u0027\u0027;\nconst userMessage = incoming.message || \u0027\u0027;\n\n// Všechny předchozí řádky z Google Sheets pro tuto konverzaci\nconst rows = $input.all().map(i =\u003e i.json).filter(r =\u003e r.conversationId === conversationId);\n\nlet history = \u0027\u0027;\nfor (const r of rows) {\n  if (!r.role || !r.text) continue;\n  if (r.role === \u0027user\u0027) history += \u0027Uživatel: \u0027 + r.text + \u0027\\n\u0027;\n  else if (r.role === \u0027assistant\u0027) history += \u0027Asistent: \u0027 + r.text + \u0027\\n\u0027;\n  else if (r.role === \u0027owner_instruction\u0027) history += \u0027Instrukce majitele webu: \u0027 + r.text + \u0027\\n\u0027;\n}\n\nreturn [{\n  json: {\n    conversationId,\n    name,\n    email,\n    userMessage,\n    history: history.trim(),\n    isFirstMessage: rows.filter(r =\u003e r.role === \u0027user\u0027 || r.role === \u0027assistant\u0027).length === 0\n  }\n}];"
                                     },
